ALTER VIEW [Advanced_Analyst].[SalesPerformance]
AS
WITH EmployeeFiltered AS
(
    SELECT 
        ur.FullNameInChinese,
        ur.UserId,
        ur.AssignBranchNo,
        b.Name AS Branch_Name,
        ur.JobTitle,                        
        CAST(ur.ArrivedDate AS date) AS ArrivedDate,
        CAST(ur.LeaveDate AS date) AS LeaveDate
    FROM [dbo].[PRO2E_AUTH_LOGIN_USER] ur
    LEFT JOIN [dbo].[SaintEir_Branch] b
        ON ur.AssignBranchNo = b.BranchNo                 
    WHERE 
    1=1
    AND (ur.JobTitle LIKE '%諮詢師%' OR ur.JobTitle LIKE '%副店長%' OR ur.JobTitle = '美容顧問' OR ur.JobTitle LIKE '%美容組長%' OR ur.JobTitle LIKE '%美容副組長%' OR ur.JobTitle LIKE '%高級美容師%') -- 20260130加入高級美容師
    AND (b.Name LIKE '%中壢%' OR b.Name LIKE '%忠孝%' OR b.Name LIKE '%桃園%' 
            OR b.Name LIKE '%新竹%' OR b.Name LIKE '%台中%' OR b.Name LIKE '%站前%' OR b.Name LIKE '%板橋%')
    AND b.Name NOT LIKE '%手術中心%'
    AND FullNameInChinese NOT LIKE '%支援%' --20260123加入，排除不具名支援人員
    AND FullNameInChinese NOT LIKE '%靜止戶%'--20260130加入，排除靜止戶
),
AliveEmployeeList AS
(
    SELECT 
        ef.FullNameInChinese,
        ef.UserId,
        ef.AssignBranchNo,
        ef.Branch_Name,
        ef.JobTitle,
        ef.ArrivedDate,
        ef.LeaveDate,
        CAST(d.date AS date) AS CheckDate
    FROM EmployeeFiltered ef
    CROSS APPLY
    (
        SELECT date
        FROM [dbo].[DateSequence]
        WHERE 
        1=1
        AND date >= ef.ArrivedDate
        AND date <= ISNULL(ef.LeaveDate,'2100-12-31')
        AND date >= DATEADD(MONTH, DATEDIFF(MONTH, 0, GETDATE()) -12, 0)
    ) AS d
),

FilteredPurchase AS (
    SELECT 
        PurchaseDate,
        BranchNo,
        SoldBy,
        CustomerName,
        CustomerBirthday, 
        PurchaseNo,
        PurchaseItemNo,
        p.ProductKeyNo,
        p.TreatmentCategory, 
        Total_Number,
        [Total_Number(Convertion)],
        [Total_Number(Convertion_Goods)],
        ANo,
        p.TreatmentItem,
        Product_Name,
        SoldOutPrice,
        m.IsPrivate
    FROM [Advanced_Analyst].[PurchaseDetail] p
    LEFT JOIN [dbo].[ProductMappingInfo] m
        ON p.ProductKeyNo = m.ProductKeyNo
    WHERE PurchaseDate >= DATEADD(MONTH, DATEDIFF(MONTH, 0, GETDATE()) - 12, 0)
),

EmployeeSalesQtyWithRN AS
(
    SELECT *
    FROM (
        SELECT
            d.PurchaseDate,
            s.RewardDate,
            s.BelongToLoginUser,
            d.CustomerName,
            d.CustomerBirthday, --20260130新增，更快速於SEOS識別查詢同名同姓消費者
            d.PurchaseNo,
            d.PurchaseItemNo,
            d.ProductKeyNo,
            d.TreatmentCategory,
            d.TreatmentItem,
            d.Product_Name, -- 20260130因應顏寧銷售稽核需計算高級美容師重點產品銷售量，加入產品名稱欄位
            d.IsPrivate,
            d.[Total_Number(Convertion)] AS Sales_Total,
            d.[Total_Number(Convertion_Goods)] AS Sales_Total_without_refund,
            s.RewardAmout,
            ROW_NUMBER() OVER (
                PARTITION BY d.PurchaseItemNo, 
                             d.ProductKeyNo,
                             d.PurchaseDate --20260112 諮詢師會議修正，避免重新分配導致跨月重複計算
                ORDER BY 
                    CAST(s.RewardDate AS DATE) ASC, --20260112 諮詢師會議修正，避免重新分配導致跨月重複計算
                    s.RewardAmout DESC
            ) AS rn
        FROM [AnalysisDB].[dbo].[SaintEir_SaleReward] s
        LEFT JOIN FilteredPurchase d
            ON s.BelongToPurchaseItemNo = d.PurchaseItemNo
           AND s.BelongToProduct = d.ProductKeyNo
        WHERE 
        1=1 
        AND s.RewardStatus = 1 -- RewardSign = 加減項 1正2負
        AND s.RewardSign = 1 --RewardStatus = 獎金狀態用來區分主要領獎金對象及服務代理，1:主要獎金 2:服務代理 3:退費扣回
        -- 20260130因應顏寧銷售稽核需計算高級美容師重點產品銷售量，加入稽核產品項目
        AND (d.TreatmentItem IN ('微整-蒙娜麗莎','高雷-IG電波','高雷-Z音波','高雷-Micools','高雷-Coresculpt核心肌塑','高雷-閨蜜電波','高雷-超玩美','微整-逆時針','微整-喬雅登 Voluma','高雷-立線音波','微整-水光針')
        OR d.Product_Name IN('璀瑟intime-清新噴霧50ml','璀瑟ROYALE-皇家金萃修護安瓶 - 8ml','璀瑟 ROYALE-皇家金萃修護安瓶 - 8ml (方)','雪妍萃EX'))
    ) AS s_inner
    WHERE s_inner.rn = 1
),

--可能要加回的換貨
AfterExchange AS (
    SELECT 
        s.PurchaseDate,
        s.BelongToLoginUser,
        s.CustomerName,
        s.RewardAmout,
        d.CustomerBirthday,
        d.BranchNo,
        s.RewardDate,
        d.PurchaseNo,
        d.PurchaseItemNo,
        d.ProductKeyNo,
        d.TreatmentCategory,
        d.TreatmentItem,
        d.Product_Name,
        d.[Total_Number(Convertion)],
        m.IsPrivate
    FROM SaintEir_SaleReward s
    INNER JOIN FilteredPurchase d 
        ON s.BelongToPurchase = d.PurchaseNo
        AND s.BelongToProduct = d.ProductKeyNo
    LEFT JOIN ProductMappingInfo m
        ON d.ProductKeyNo = m.ProductKeyNo
    WHERE s.RewardAmout = 0
      AND s.RewardDate IS NULL
      AND d.Ano = '0'
      AND (d.TreatmentItem IN ('微整-蒙娜麗莎','高雷-IG電波','高雷-Z音波','高雷-Micools','高雷-Coresculpt核心肌塑')
           OR d.Product_Name IN ('璀瑟intime-清新噴霧50ml','璀瑟ROYALE-皇家金萃修護安瓶 - 8ml','璀瑟 ROYALE-皇家金萃修護安瓶 - 8ml (方)','雪妍萃EX'))
),

--換貨路徑
ExchangeProcess AS (
    SELECT 
        d0.PurchaseDate AS BeforeExchangePurchaseDate,
        d0.BranchNo AS BeforeExchangeBranchNo,
        d0.SoldBy AS BeforeExchangeUserId,
        d0.CustomerName AS BeforeExchangeCustomerName,
        d0.CustomerBirthday AS BeforeExchangeCustomerBirhday,
        d0.PurchaseNo AS BeforeExchangePurchaseNo,
        d0.PurchaseItemNo AS BeforeExchangePurchaseItemNo,
        d0.ProductKeyNo AS BeforeExchangeProductKeyNo,
        d0.TreatmentCategory AS BeforeExchangeTreatmentCategory,
        d0.TreatmentItem AS BeforeExchangeTreatmentItem,
        d0.Product_Name AS BeforeExchangeProductName,
        d0.[Total_Number(Convertion)] AS BeforeExchangeQty,
        --g.Quantity AS ExchangeQuantity,
        d2.PurchaseDate AS AfterExchangePurchaseDate,
        d2.BranchNo AS AfterExchangeBranchNo,
        d2.SoldBy AS AfterExchangeUserId,
        d2.CustomerName AS AfterExchangeCustomerName,
        d2.CustomerBirthday AS AfterExchangeCustomerBirhday,
        d2.PurchaseNo AS AfterExchangePurchaseNo,
        d2.PurchaseItemNo AS AfterExchangePurchaseItemNo,
        d2.ProductKeyNo AS AfterExchangeProductKeyNo,
        d2.TreatmentCategory AS AfterExchangeTreatmentCategory,
        d2.TreatmentItem AS AfterExchangeTreatmentItem,
        d2.Product_Name AS AfterExchangeProductName,
        d2.[Total_Number(Convertion)] AS AfterExchangeQty
    FROM SaintEir_GoodsExchange g
    INNER JOIN FilteredPurchase d0 ON g.BelongToProduct = d0.ProductKeyNo AND g.BelongToPurchaseItem = d0.PurchaseItemNo
    LEFT JOIN SaintEir_Credit c ON g.BelongToPurchase = c.BelongToPurchase
    LEFT JOIN FilteredPurchase d1 ON c.PurchaseTo = d1.PurchaseNo
    LEFT JOIN [dbo].[SaintEir_PurchaseItemCredit] pc ON d1.PurchaseItemNo = pc.PurchaseItemFrom
    LEFT JOIN FilteredPurchase d2 ON pc.PurchaseItemTo = d2.PurchaseItemNo
),

--換貨結果
ExchangeResult AS (
    SELECT *
    FROM(SELECT
        a.PurchaseDate,
        ep.*,
        CASE WHEN DATEDIFF(MONTH, ep.BeforeExchangePurchaseDate, ep.AfterExchangePurchaseDate) = 0 THEN 1 ELSE 0 END AS Same_month,
        ROW_NUMBER() OVER (
            PARTITION BY a.PurchaseItemNo 
            ORDER BY ep.BeforeExchangePurchaseDate DESC
        ) AS RowNum,
        a.IsPrivate AS AfterExchangeIsPrivate
    FROM AfterExchange a
    INNER JOIN ExchangeProcess ep
        ON a.PurchaseItemNo = ep.AfterExchangePurchaseItemNo
        ) AS ExchangeResult_Base
    WHERE RowNum = 1
),

EmployeeUseQty AS(
    SELECT
        d.PurchaseDate,
        ch.ConsumptionDate AS use_date,
        d.BranchNo,
        u.JobTitle,
        e.BelongToLoginUser AS UserId,
        u.FullNameInChinese,
        d.CustomerName,
        d.CustomerBirthday, --20260130新增，更快速於SEOS識別查詢同名同姓消費者
        d.PurchaseNo,
        d.PurchaseItemNo,
        d.ProductKeyNo,
        m.TreatmentCategory,
        m.TreatmentItem,
        m.ProductName, -- 20260130因應顏寧銷售稽核需計算高級美容師重點產品銷售量，加入產品名稱欄位
        m.IsPrivate,
        e.RewardAmout,
        er.BeforeExchangePurchaseItemNo,
        er.BeforeExchangeProductKeyNo,
        ch.Quantity AS use_qty
    FROM [dbo].[SaintEir_ComsumptionHistory] AS ch
    LEFT JOIN ExchangeResult er
        ON ch.BelongToPurchaseItem = er.AfterExchangePurchaseItemNo
        AND ch.ConsumptionProduct = er.AfterExchangeProductKeyNo
    LEFT JOIN FilteredPurchase d 
        ON ch.ConsumptionProduct = d.ProductKeyNo
        AND ch.BelongToPurchaseItem = d.PurchaseItemNo
    LEFT JOIN [dbo].[ProductMappingInfo] m
        ON d.ProductKeyNo = m.ProductKeyNo
    LEFT JOIN EmployeeSalesQtyWithRN e 
        ON e.ProductKeyNo = COALESCE(er.BeforeExchangeProductKeyNo, ch.ConsumptionProduct)
        AND e.PurchaseItemNo = COALESCE(er.BeforeExchangePurchaseItemNo, ch.BelongToPurchaseItem)
    LEFT JOIN [dbo].[PRO2E_AUTH_LOGIN_USER] AS u
        ON e.BelongToLoginUser = u.UserId
    WHERE
    1=1
    AND d.ProductKeyNo IN('3916','4264','4270')
    AND d.SoldOutPrice > 0
    AND ch.flag = 1
),

-- ================== 最終輸出 ==================
--銷售量(含退換貨Qty_without_refund)
CombineAll AS(
SELECT
    e.CheckDate,
    PurchaseDate,
    RewardDate AS RewardOrUseDate,
    e.UserId,
    e.FullNameInChinese,
    e.Branch_Name,
    e.JobTitle,
    e.ArrivedDate,
    e.LeaveDate,
    s.CustomerName,
    s.CustomerBirthday,--20260130新增，更快速於SEOS識別查詢同名同姓消費者
    TreatmentCategory,
    TreatmentItem,
    Product_Name,-- 20260130因應顏寧銷售稽核需計算高級美容師重點產品銷售量，加入產品名稱欄位
    PurchaseNo,
    ProductKeyNo,
    IsPrivate,
    ISNULL(s.Sales_Total, 0) AS Qty, 
    ISNULL(s.Sales_Total_without_refund, 0) AS Qty_without_refund,
    'Sales' AS SalesOrUse,
    RewardAmout,
    NULL AS Same_month
FROM AliveEmployeeList e
LEFT JOIN EmployeeSalesQtyWithRN s
    ON e.UserId = s.BelongToLoginUser
    AND e.CheckDate = CAST(s.RewardDate AS DATE)

UNION

--操作量
SELECT
    e.CheckDate,
    PurchaseDate,
    use_date AS RewardOrUseDate,
    e.UserId,
    e.FullNameInChinese,
    e.Branch_Name,
    e.JobTitle,
    e.ArrivedDate,
    e.LeaveDate,
    CustomerName,
    CustomerBirthday,--20260130新增，更快速於SEOS識別查詢同名同姓消費者
    TreatmentCategory,
    TreatmentItem,
    ProductName,-- 20260130因應顏寧銷售稽核需計算高級美容師重點產品銷售量，加入產品名稱欄位
    PurchaseNo, 
    ProductKeyNo,
    IsPrivate,
    ISNULL(use_qty, 0) AS Qty,
    NULL AS Qty_without_refund,
   'Use' AS SalesOrUse,
   RewardAmout,
   NULL AS Same_month
FROM AliveEmployeeList e
LEFT JOIN EmployeeUseQty uq
    ON e.UserId = uq.UserId
    AND e.CheckDate = CAST(uq.use_date AS DATE)

UNION

--20260209新增同月換貨加回
SELECT
    e.CheckDate,
    er.AfterExchangePurchaseDate,
    NULL AS RewardOrUseDate,
    e.UserId,
    e.FullNameInChinese,
    e.Branch_Name,
    e.JobTitle,
    e.ArrivedDate,
    e.LeaveDate,
    er.AfterExchangeCustomerName,
    er.AfterExchangeCustomerBirhday,--20260130新增，更快速於SEOS識別查詢同名同姓消費者
    er.AfterExchangeTreatmentCategory,
    er.AfterExchangeTreatmentItem,
    er.AfterExchangeProductName,-- 20260130因應顏寧銷售稽核需計算高級美容師重點產品銷售量，加入產品名稱欄位
    er.AfterExchangePurchaseNo,
    er.AfterExchangeProductKeyNo,
    er.AfterExchangeIsPrivate,
    ISNULL(er.AfterExchangeQty, 0) AS Qty, 
    NULL AS Qty_without_refund,
    'Sales(Exchanged)' AS SalesOrUse,
    NULL AS RewardAmout,
    er.Same_month
FROM AliveEmployeeList e
LEFT JOIN ExchangeResult er
ON e.CheckDate = CAST(er.AfterExchangePurchaseDate AS DATE)
AND e.UserId = er.BeforeExchangeUserId --20260304避免消費者將商品轉讓給其他消費者時時，銷售人員更換導致原銷售人員銷售量未被加回
)

SELECT DISTINCT
*
FROM CombineAll
WHERE
1=1
